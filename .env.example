# Private/gated Hugging Face models require a read token.
HF_TOKEN=hf_your_token_here

# Ollama in another container. This works when its port 11434 is published on the host.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Run `id -u` and `id -g` if your host user is not 1000:1000.
PUID=1000
PGID=1000
